{
  "name": "sso-bot-sample",
  "version": "1.0.0",
  "description": "Microsoft Teams Toolkit sso bot sample",
  "engines": {
    "node": "18 || 20 || 22"
  },
  "author": "Microsoft",
  "license": "MIT",
  "main": "./dist/src/index.js",
  "scripts": {
    "dev:teamsfx": "env-cmd --silent -f .localConfigs npm run dev",
    "predev": "npm run build",
    "dev": "npx func start --typescript --language-worker=\"--inspect=9239\" --port \"3978\" --cors \"*\"",
    "dev-old": "nodemon --exec node --inspect=9239 --signal SIGINT -r ts-node/register ./src/index.ts",
    "prepare-storage:teamsfx": "azurite --silent --location ./_storage_emulator --debug ./_storage_emulator/debug.log",
    "watch:teamsfx": "tsc --watch",
    "build": "tsc --build",
    "start": "node ./dist/src/index.js",
    "watch": "nodemon --exec \"npm run start\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com"
  },
  "dependencies": {
    "@azure/service-bus": "^7.9.5",
    "@azure/storage-blob": "^12.9.0",
    "@microsoft/microsoft-graph-client": "^3.0.1",
    "@microsoft/teamsfx": "^3.0.0-alpha",
    "azure-functions-core-tools": "^4.3.0",
    "azurite": "^3.35.0",
    "botbuilder": "^4.23.1",
    "botbuilder-dialogs": "^4.23.1",
    "express": "^5.0.1",
    "isomorphic-fetch": "^3.0.0",
    "openai": "^5.20.0",
    "pg": "^8.16.3",
    "typeorm": "^0.3.27",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@azure/functions": "^1.2.3",
    "@types/express": "^5.0.0",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^18.0.0",
    "env-cmd": "^10.1.0",
    "nodemon": "^3.1.7",
    "shx": "^0.3.3",
    "ts-node": "^10.4.0",
    "typescript": "^5.3.0"
  }
}
